# Vite environment variables for the SPA.
# Copy this file to `.env.local` and fill in real values for your environment.
# `.env.local` is gitignored — never commit it.

# Backend API base URL (HTTP API stage URL or custom domain).
VITE_API_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com

# Public app URL (used for OAuth redirects and absolute links).
VITE_APP_URL=https://<your-cloudfront-or-localhost>

# Cognito user-pool wiring (must match the pool the API authorizer trusts).
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com

# Owner / admin email — gates admin-only UI surfaces (visibility overrides,
# CostBadge, AdminSettings, etc.). Must exactly match the `ADMIN_EMAIL`
# constant in `infrastructure/lib/foot-solutions-stack.ts` so the SPA and
# the Lambdas agree on who counts as admin. The SPA falls back to the
# build-time default in `src/lib/admin.ts` if this is unset.
VITE_ADMIN_EMAIL=
